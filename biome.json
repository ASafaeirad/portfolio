{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "useEditorconfig": true,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noCommonJs": "error",
        "noNamespace": "error",
        "useAsConstAssertion": "error",
        "useConsistentObjectDefinitions": "warn"
      },
      "suspicious": {
        "noConstantBinaryExpressions": "error"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteProperties": "preserve",
      "quoteStyle": "single"
    }
  },
  "html": {
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "selfCloseVoidElements": "always"
    }
  },
  "assist": {
    "actions": {
      "source": {
        "recommended": true,
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [{ "type": true, "source": null }, ":URL:", ":NODE:"]
          }
        }
      }
    }
  }
}
